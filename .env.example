# Environment variables for the Docker evaluation stack.
# Copy or source this file when running docker compose manually.
# docker compose --env-file .env.example up -d

ENDURE_DATABASE_NAME=endure
ENDURE_DATABASE_USER=postgres
ENDURE_DATABASE_PASSWORD=postgres
ENDURE_DATABASE_HOST=localhost
ENDURE_DATABASE_PORT=5432

ENDURE_REDIS_URL=redis://localhost:6379/0

ENDURE_API_HOST=0.0.0.0
ENDURE_API_PORT=8000

ENDURE_SCHEDULER_LOOP_INTERVAL=1.0
ENDURE_LEADER_HEARTBEAT_INTERVAL=5.0
ENDURE_LEADER_LOCK_TTL=15.0

ENDURE_WORKER_MAX_INFLIGHT_JOBS=4
ENDURE_WORKER_HEARTBEAT_INTERVAL=5.0
ENDURE_WORKER_HEARTBEAT_TIMEOUT=30.0

ENDURE_DEFAULT_JOB_TIMEOUT=3600
ENDURE_DEFAULT_MAX_RETRIES=3
ENDURE_RETRY_BASE_DELAY=5.0
ENDURE_RETRY_MAX_DELAY=300.0

ENDURE_CHECKPOINT_DIR=/tmp/endure-checkpoints